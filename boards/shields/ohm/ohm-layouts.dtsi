#include <dt-bindings/zmk/matrix_transform.h> // Put this with the other includes at the top of your dtsi
#include <physical_layouts.dtsi>

// Positions converted from Fusion 360 mm coordinates using scale = 100 cu / 18.1 mm,
// so the physical 18.1 mm key pitch maps to exactly 100 cu — matching the rendered
// 100×100 (1U) key size for a gap-free but non-overlapping layout in ZMK Studio /
// keymap-drawer.
// rot: 1000 cd = 10° CW (left half), -1000 cd = 10° CCW (right half).
// If the halves lean the wrong way, negate every rot value.
//
/ {
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default";

        kscan = <&kscan0>;
        transform = <&default_transform>;

        keys  //                     w   h    x    y     rot    rx    ry
            // Left row 0  (Q W E R T)
            = <&key_physical_attrs 100 100   33    8    1000    83    58>
            , <&key_physical_attrs 100 100  136    0    1000   186    50>
            , <&key_physical_attrs 100 100  237    4    1000   287    54>
            , <&key_physical_attrs 100 100  333   35    1000   383    85>
            , <&key_physical_attrs 100 100  429   65    1000   479   115>
            // Right row 0  (Y U I O P)
            , <&key_physical_attrs 100 100  643   65   (-1000)  693   115>
            , <&key_physical_attrs 100 100  739   35   (-1000)  789    85>
            , <&key_physical_attrs 100 100  835    4   (-1000)  885    54>
            , <&key_physical_attrs 100 100  936    0   (-1000)  986    50>
            , <&key_physical_attrs 100 100 1039    8   (-1000) 1089    58>
            // Left row 1  (A S D F G)
            , <&key_physical_attrs 100 100   16  102    1000    66   152>
            , <&key_physical_attrs 100 100  119   93    1000   169   143>
            , <&key_physical_attrs 100 100  220   97    1000   270   147>
            , <&key_physical_attrs 100 100  316  128    1000   366   178>
            , <&key_physical_attrs 100 100  413  158    1000   463   208>
            // Right row 1  (H J K L ;)
            , <&key_physical_attrs 100 100  659  158   (-1000)  709   208>
            , <&key_physical_attrs 100 100  755  128   (-1000)  805   178>
            , <&key_physical_attrs 100 100  852   97   (-1000)  902   147>
            , <&key_physical_attrs 100 100  952   93   (-1000) 1002   143>
            , <&key_physical_attrs 100 100 1055  102   (-1000) 1105   152>
            // Left row 2  (Z X C V B)
            , <&key_physical_attrs 100 100    0  195    1000    50   245>
            , <&key_physical_attrs 100 100  103  186    1000   153   236>
            , <&key_physical_attrs 100 100  204  190    1000   254   240>
            , <&key_physical_attrs 100 100  300  221    1000   350   271>
            , <&key_physical_attrs 100 100  396  251    1000   446   301>
            // Right row 2  (N M , . ')
            , <&key_physical_attrs 100 100  676  251   (-1000)  726   301>
            , <&key_physical_attrs 100 100  772  221   (-1000)  822   271>
            , <&key_physical_attrs 100 100  868  190   (-1000)  918   240>
            , <&key_physical_attrs 100 100  969  186   (-1000) 1019   236>
            , <&key_physical_attrs 100 100 1072  195   (-1000) 1122   245>
            // Left thumb
            , <&key_physical_attrs 100 100  284  314    1000   334   364>
            , <&key_physical_attrs 100 100  380  344    1000   430   394>
            , <&key_physical_attrs 100 100  476  375    1000   526   425>
            // Right thumb
            , <&key_physical_attrs 100 100  596  375   (-1000)  646   425>
            , <&key_physical_attrs 100 100  692  344   (-1000)  742   394>
            , <&key_physical_attrs 100 100  788  314   (-1000)  838   364>
            ;
    };
};

/ {
    chosen {
        zmk,physical-layout = &physical_layout0;
        // Other chosen items
    };
};
