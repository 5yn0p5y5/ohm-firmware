#include <dt-bindings/zmk/matrix_transform.h> // Put this with the other includes at the top of your dtsi
#include <physical_layouts.dtsi>

// Positions derived from Fusion 360 switch-center coordinates (left-side.csv).
// scale = 5.249 cu/mm (100 cu / 19.05 mm MX pitch).
// cu_cx = csv_x * 5.249 + 589,  cu_cy = -csv_y * 5.249 + 122
// Right half mirrored: cx_right = 1178 - cx_left, cy_right = cy_left
// x = cx - 50, y = cy - 50, rx = cx, ry = cy
// rot: 1000 = 10° CW (left half), -1000 = 10° CCW (right half).
//
/ {
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default";

        kscan = <&kscan0>;
        transform = <&default_transform>;

        keys  //                     w   h    x    y     rot    rx    ry
            // Left row 0  (Q W E R T)
            = <&key_physical_attrs 100 100   38   18    1000    88    68>
            , <&key_physical_attrs 100 100  141   11    1000   191    61>
            , <&key_physical_attrs 100 100  241   16    1000   291    66>
            , <&key_physical_attrs 100 100  338   46    1000   388    96>
            , <&key_physical_attrs 100 100  434   75    1000   484   125>
            // Right row 0  (Y U I O P)
            , <&key_physical_attrs 100 100  644   75   (-1000)  694   125>
            , <&key_physical_attrs 100 100  740   46   (-1000)  790    96>
            , <&key_physical_attrs 100 100  837   16   (-1000)  887    66>
            , <&key_physical_attrs 100 100  937   11   (-1000)  987    61>
            , <&key_physical_attrs 100 100 1040   18   (-1000) 1090    68>
            // Left row 1  (A S D F G)
            , <&key_physical_attrs 100 100   21  117    1000    71   167>
            , <&key_physical_attrs 100 100  123  109    1000   173   159>
            , <&key_physical_attrs 100 100  224  114    1000   274   164>
            , <&key_physical_attrs 100 100  320  144    1000   370   194>
            , <&key_physical_attrs 100 100  417  174    1000   467   224>
            // Right row 1  (H J K L ;)
            , <&key_physical_attrs 100 100  661  174   (-1000)  711   224>
            , <&key_physical_attrs 100 100  758  144   (-1000)  808   194>
            , <&key_physical_attrs 100 100  854  114   (-1000)  904   164>
            , <&key_physical_attrs 100 100  955  109   (-1000) 1005   159>
            , <&key_physical_attrs 100 100 1057  117   (-1000) 1107   167>
            // Left row 2  (Z X C V B)
            , <&key_physical_attrs 100 100    3  215    1000    53   265>
            , <&key_physical_attrs 100 100  106  208    1000   156   258>
            , <&key_physical_attrs 100 100  207  213    1000   257   263>
            , <&key_physical_attrs 100 100  303  242    1000   353   292>
            , <&key_physical_attrs 100 100  399  272    1000   449   322>
            // Right row 2  (N M , . ')
            , <&key_physical_attrs 100 100  679  272   (-1000)  729   322>
            , <&key_physical_attrs 100 100  775  242   (-1000)  825   292>
            , <&key_physical_attrs 100 100  871  213   (-1000)  921   263>
            , <&key_physical_attrs 100 100  972  208   (-1000) 1022   258>
            , <&key_physical_attrs 100 100 1075  215   (-1000) 1125   265>
            // Left thumb
            , <&key_physical_attrs 100 100  286  341    1000   336   391>
            , <&key_physical_attrs 100 100  382  371    1000   432   421>
            , <&key_physical_attrs 100 100  478  401    1000   528   451>
            // Right thumb
            , <&key_physical_attrs 100 100  600  401   (-1000)  650   451>
            , <&key_physical_attrs 100 100  696  371   (-1000)  746   421>
            , <&key_physical_attrs 100 100  792  341   (-1000)  842   391>
            ;
    };
};

/ {
    chosen {
        zmk,physical-layout = &physical_layout0;
        // Other chosen items
    };
};
