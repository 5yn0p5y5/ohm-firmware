#include <dt-bindings/zmk/matrix_transform.h> // Put this with the other includes at the top of your dtsi
#include <physical_layouts.dtsi>

// Coordinates derived from the Ohm web app display positions (Fusion 360 mm coords
// un-rotated by 10° per half, then converted to ZMK centiunits: 100 cu = 1U = 19.05 mm).
// Rotation: 1000 centidegrees = 10° clockwise (left half), -1000 = 10° counter-clockwise (right half).
// Each key rotates around its own centre (rx, ry).
// If ZMK Studio shows the halves leaning the wrong way, negate all rot values.
//
/ {
    physical_layout0: physical_layout_0 {
        compatible = "zmk,physical-layout";
        display-name = "Default";

        kscan = <&kscan0>;
        transform = <&default_transform>;

        keys  //                     w   h    x    y     rot    rx    ry
            // Left row 0  (Q W E R T)
            = <&key_physical_attrs 100 100    0   38    1000    50    88>
            , <&key_physical_attrs 100 100   95   13    1000   145    63>
            , <&key_physical_attrs 100 100  190    0    1000   240    50>
            , <&key_physical_attrs 100 100  285   13    1000   335    63>
            , <&key_physical_attrs 100 100  380   25    1000   430    75>
            // Right row 0  (Y U I O P)
            , <&key_physical_attrs 100 100  581   25   (-1000)  631    75>
            , <&key_physical_attrs 100 100  676   13   (-1000)  726    63>
            , <&key_physical_attrs 100 100  771    0   (-1000)  821    50>
            , <&key_physical_attrs 100 100  866   13   (-1000)  916    63>
            , <&key_physical_attrs 100 100  960   38   (-1000) 1010    88>
            // Left row 1  (A S D F G)
            , <&key_physical_attrs 100 100    0  127    1000    50   177>
            , <&key_physical_attrs 100 100   95  102    1000   145   152>
            , <&key_physical_attrs 100 100  190   90    1000   240   140>
            , <&key_physical_attrs 100 100  285  102    1000   335   152>
            , <&key_physical_attrs 100 100  380  115    1000   430   165>
            // Right row 1  (H J K L ;)
            , <&key_physical_attrs 100 100  581  115   (-1000)  631   165>
            , <&key_physical_attrs 100 100  676  102   (-1000)  726   152>
            , <&key_physical_attrs 100 100  771   90   (-1000)  821   140>
            , <&key_physical_attrs 100 100  866  102   (-1000)  916   152>
            , <&key_physical_attrs 100 100  961  127   (-1000) 1011   177>
            // Left row 2  (Z X C V B)
            , <&key_physical_attrs 100 100    0  217    1000    50   267>
            , <&key_physical_attrs 100 100   95  192    1000   145   242>
            , <&key_physical_attrs 100 100  190  180    1000   240   230>
            , <&key_physical_attrs 100 100  285  192    1000   335   242>
            , <&key_physical_attrs 100 100  380  205    1000   430   255>
            // Right row 2  (N M , . ')
            , <&key_physical_attrs 100 100  581  205   (-1000)  631   255>
            , <&key_physical_attrs 100 100  676  192   (-1000)  726   242>
            , <&key_physical_attrs 100 100  771  180   (-1000)  821   230>
            , <&key_physical_attrs 100 100  866  192   (-1000)  916   242>
            , <&key_physical_attrs 100 100  961  217   (-1000) 1011   267>
            // Left thumb
            , <&key_physical_attrs 100 100  285  282    1000   335   332>
            , <&key_physical_attrs 100 100  380  295    1000   430   345>
            , <&key_physical_attrs 100 100  475  307    1000   525   357>
            // Right thumb
            , <&key_physical_attrs 100 100  486  307   (-1000)  536   357>
            , <&key_physical_attrs 100 100  581  295   (-1000)  631   345>
            , <&key_physical_attrs 100 100  676  282   (-1000)  726   332>
            ;
    };
};

/ {
    chosen {
        zmk,physical-layout = &physical_layout0;
        // Other chosen items
    };
};
